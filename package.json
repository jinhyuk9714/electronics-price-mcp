{
  "name": "electronics-price-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "한국 전자기기 검색과 현재 가격 비교를 위한 원격 MCP 서버",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:danawa-canary": "wrangler deploy --env danawa-canary",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "eval:service-quality": "node --experimental-strip-types scripts/run-service-quality-eval.ts",
    "eval:service-quality:advanced": "node --experimental-strip-types scripts/run-service-quality-eval.ts --suite service-quality-advanced-100",
    "eval:service-quality:canary": "SERVICE_QUALITY_TARGET=danawa-canary node --experimental-strip-types scripts/run-service-quality-eval.ts",
    "eval:service-quality:advanced:canary": "SERVICE_QUALITY_TARGET=danawa-canary node --experimental-strip-types scripts/run-service-quality-eval.ts --suite service-quality-advanced-100",
    "smoke:danawa": "tsx scripts/run-danawa-smoke.ts",
    "smoke:static-catalog": "tsx scripts/run-static-catalog-smoke.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.12.5",
    "zod": "^4.0.18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260110.0",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
