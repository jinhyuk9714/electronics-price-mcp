## 로컬 실행 또는 직접 배포할 때만 사용합니다.
## 공개 배포본을 원격 MCP로 붙여 쓰는 경우에는 필요하지 않습니다.

NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
ENABLE_DANAWA=false
ENABLE_STATIC_CATALOG=false
STATIC_CATALOG_DATASET=core-exact-v1
DANAWA_CLIENT_ID=your_danawa_client_id
DANAWA_CLIENT_SECRET=your_danawa_client_secret
DANAWA_API_BASE_URL=http://api.danawa.com
REQUEST_TIMEOUT_MS=8000
CACHE_TTL_MS=300000
PUBLIC_BASE_URL=https://electronics-price-mcp.jinhyuk9714.workers.dev
CHATGPT_APP_URL=

## ELECTRONICS_RATE_LIMITER는 wrangler.toml Durable Object binding으로 주입됩니다.
## .dev.vars에 직접 넣지 않습니다.
## danawa-canary 배포에서는 wrangler.toml의 env.danawa-canary.vars가 ENABLE_DANAWA=true를 강제합니다.
## 정적 카탈로그는 canary/dev fallback 용도이며 production 기본값은 ENABLE_STATIC_CATALOG=false입니다.
## danawa-canary는 STATIC_CATALOG_DATASET=canary-eval-v1를 기본으로 사용합니다.
